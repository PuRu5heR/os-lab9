<h2>Каталог игрушек</h2>
<p>Здесь вы можете управлять списком игрушек: добавлять, удалять, смотреть описание.</p>

<div class="button-group">
    <button class="btn-add" onclick="OnAddValueButtonClick()">Добавить игрушку</button>
    <button class="btn-update" onclick="OnUpdateValueButtonClick()">Обновить игрушку</button>
    <button class="btn-delete" onclick="OnDeleteValueButtonClick()">Удалить игрушку</button>
    <button class="btn-info" onclick="getToyById()">Найти игрушку</button>
    <button class="btn-list" onclick="loadToysFromServer()">Обновить таблицу</button>
    <button class="btn-download" onclick="downloadToysJSON()">Скачать JSON файл</button>
</div>

<div class="search-sort-panel">
    <div class="search-box">
        <input type="text" id="searchInput" placeholder="Поиск по названию..." onkeyup="onSearchInput()">
        <button onclick="clearSearch()" class="btn-clear">Очистить</button>
    </div>
    <div class="sort-box">
        <label>Сортировать по названию:</label>
        <button onclick="setSortOrder('asc')" class="btn-sort">А → Я</button>
        <button onclick="setSortOrder('desc')" class="btn-sort">Я → А</button>
        <button onclick="setSortOrder('none')" class="btn-sort">Без сортировки</button>
    </div>
</div>

<div class="per-page-box">
    <label>Показывать:</label>
    <select id="perPageSelect" onchange="changeItemsPerPage()">
        <option value="5">5</option>
        <option value="10">10</option>
        <option value="20">20</option>
        <option value="50">50</option>
    </select>
</div>

<table class="toys-table" id="toys-table">
    <thead>
        <tr><th>Название игрушки</th><th>Описание ухода / особенности</th></tr>
    </thead>
    <tbody id="toys-table-body">
        <tr><td colspan="2">Загрузка...</td></tr>
    </tbody>
</table>

<div class="pagination-controls" id="pagination-controls">
    <button onclick="goToPage(1)" class="btn-page" id="btn-first">Первая</button>
    <button onclick="goToPage(currentPage - 1)" class="btn-page" id="btn-prev">Назад</button>
    <span class="page-info" id="page-info">Страница 1 из 1</span>
    <button onclick="goToPage(currentPage + 1)" class="btn-page" id="btn-next">Вперед</button>
    <button onclick="goToPage(2000000000)" class="btn-page" id="btn-last">Последняя</button>
</div>

<div id="info-message" class="info-panel">
</div>

<style>
    .search-sort-panel {
        background-color: #f0f0f0;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        align-items: center;
    }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
        flex: 2;
    }

    .search-box input {
        padding: 8px 12px;
        font-size: 14px;
        border: 1px solid #ddd;
        border-radius: 5px;
        flex: 1;
        min-width: 200px;
    }

    .sort-box {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sort-box label {
        font-weight: bold;
        color: #2c3e50;
    }

    .btn-clear {
        background-color: #95a5a6;
        color: white;
        padding: 8px 16px;
    }

    .btn-sort {
        background-color: #3498db;
        color: white;
        padding: 8px 16px;
    }

    .pagination-controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        margin-top: 20px;
        padding: 15px;
        background-color: #f9f9f9;
        border-radius: 8px;
        flex-wrap: wrap;
    }

    .btn-page {
        background-color: #2c3e50;
        color: white;
        padding: 8px 16px;
    }

    .btn-page:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-info {
        font-weight: bold;
        color: #2c3e50;
        min-width: 150px;
        text-align: center;
    }

    .stats-info {
        color: #7f8c8d;
        font-size: 14px;
        margin-top: 10px;
        text-align: center;
    }
</style>

<script>
    let currentToys = {};
    let currentPage = 1;
    let itemsPerPage = 5;
    let currentSort = 'none';
    let currentSearchTerm = '';
    let totalItems = 0;
    let totalPages = 1;
    let updatingFromHash = false;

    function showInfoMessage(text) {
        const infoDiv = document.getElementById("info-message");
        if (infoDiv) {
            infoDiv.innerHTML = text.replace(/\n/g, '<br>');
        }
    }

    function getHashParams() {
        const hash = window.location.hash.slice(1);
        const params = new URLSearchParams(hash);
        return {
            page: parseInt(params.get('page')) || 1,
            limit: parseInt(params.get('limit')) || 5,
            sort: params.get('sort') || 'none',
            search: params.get('search') || ''
        };
    }

    function updateHash() {
        if (updatingFromHash) return;

        const params = new URLSearchParams();
        if (currentPage > 1) params.set('page', currentPage);
        if (itemsPerPage !== 5) params.set('limit', itemsPerPage);
        if (currentSort !== 'none') params.set('sort', currentSort);
        if (currentSearchTerm) params.set('search', currentSearchTerm);

        const hash = params.toString();
        const newHash = hash ? '#' + hash : '#';

        if (window.location.hash !== newHash) {
            window.location.hash = newHash;
        }
    }

    async function loadToysFromServer() {
        try {
            showInfoMessage("Загрузка данных с сервера...");

            const params = new URLSearchParams();
            params.set('page', currentPage);
            params.set('limit', itemsPerPage);
            params.set('sort', currentSort);
            if (currentSearchTerm) params.set('search', currentSearchTerm);

            const response = await fetch(`/api/toys?${params.toString()}`);
            if (!response.ok) throw new Error('Ошибка загрузки данных');

            const data = await response.json();

            currentToys = data.items;
            totalItems = data.totalItems;
            totalPages = data.totalPages;
            currentPage = data.currentPage;

            renderToysTable();
            updatePaginationControls();

            const searchInfo = currentSearchTerm ? ` (поиск: "${currentSearchTerm}")` : '';
            const sortInfo = currentSort !== 'none' ? `, сортировка: ${currentSort === 'asc' ? 'А→Я' : 'Я→А'}` : '';
            showInfoMessage(`Показано ${Object.keys(currentToys).length} из ${totalItems} игрушек${searchInfo}${sortInfo}`);
        } catch (error) {
            console.error('Ошибка:', error);
            showInfoMessage('Ошибка загрузки данных: ' + error.message);
        }
    }

    function renderToysTable() {
        const tbody = document.getElementById("toys-table-body");
        if (!tbody) return;

        const keys = Object.keys(currentToys);

        if (keys.length === 0) {
            let message = currentSearchTerm ? `Ничего не найдено по запросу "${currentSearchTerm}"` : "Каталог пуст. Добавьте первую игрушку!";
            tbody.innerHTML = `<td><td colspan="2" style="text-align: center;">${message}</td></tr>`;
            return;
        }

        let html = "";
        for (let key of keys) {
            html += `<tr><td><strong>${escapeHtml(key)}</strong></td><td>${escapeHtml(currentToys[key])}</td></tr>`;
        }
        tbody.innerHTML = html;
    }

    function updatePaginationControls() {
        const pageInfo = document.getElementById("page-info");
        const btnFirst = document.getElementById("btn-first");
        const btnPrev = document.getElementById("btn-prev");
        const btnNext = document.getElementById("btn-next");
        const btnLast = document.getElementById("btn-last");

        if (pageInfo) {
            if (totalItems === 0) {
                pageInfo.innerHTML = "Страница 0 из 0";
            } else {
                pageInfo.innerHTML = `Страница ${currentPage} из ${totalPages} (всего: ${totalItems})`;
            }
        }

        if (btnFirst) btnFirst.disabled = currentPage === 1 || totalItems === 0;
        if (btnPrev) btnPrev.disabled = currentPage === 1 || totalItems === 0;
        if (btnNext) btnNext.disabled = currentPage === totalPages || totalItems === 0;
        if (btnLast) btnLast.disabled = currentPage === totalPages || totalItems === 0;
    }

    function goToPage(page) {
        if (page < 1 || page > totalPages || totalItems === 0) return;
        currentPage = page;
        updateHash();
        loadToysFromServer();
    }

    function onSearchInput() {
        currentSearchTerm = document.getElementById("searchInput").value;
        currentPage = 1;
        updateHash();
        loadToysFromServer();
    }

    function clearSearch() {
        document.getElementById("searchInput").value = "";
        currentSearchTerm = "";
        currentPage = 1;
        updateHash();
        loadToysFromServer();
    }

    function setSortOrder(order) {
        currentSort = order;
        currentPage = 1;
        updateHash();
        loadToysFromServer();
    }

    function changeItemsPerPage() {
        itemsPerPage = parseInt(document.getElementById('perPageSelect').value);
        currentPage = 1;
        updateHash();
        loadToysFromServer();
    }

    function onHashChange() {
        updatingFromHash = true;

        const params = getHashParams();
        currentPage = params.page;
        itemsPerPage = params.limit;
        currentSort = params.sort;
        currentSearchTerm = params.search;

        document.getElementById('searchInput').value = currentSearchTerm;
        document.getElementById('perPageSelect').value = itemsPerPage;

        updatingFromHash = false;
        loadToysFromServer();
    }

    async function getToyById() {
        let toyName = prompt("Введите название игрушки для получения информации:");
        if (!toyName || toyName.trim() === "") {
            showInfoMessage("Запрос отменён.");
            return;
        }

        const name = toyName.trim();

        try {
            showInfoMessage(`Поиск игрушки "${name}"...`);
            const response = await fetch(`/api/toys/${encodeURIComponent(name)}`);

            if (!response.ok) {
                if (response.status === 404) throw new Error('Игрушка не найдена');
                throw new Error('Ошибка получения данных');
            }

            const toy = await response.json();
            showInfoMessage(`Найдено:\nНазвание: ${toy.id}\nОписание: ${toy.description}`);
        } catch (error) {
            showInfoMessage(`${error.message}`);
        }
    }

    async function OnAddValueButtonClick() {
        let toyName = prompt("Введите название игрушки:");
        if (!toyName || toyName.trim() === "") {
            showInfoMessage("Добавление отменено: название не введено.");
            return;
        }

        let toyDescription = prompt("Введите описание игрушки:");
        if (!toyDescription || toyDescription.trim() === "") {
            showInfoMessage("Добавление отменено: описание не введено.");
            return;
        }

        const name = toyName.trim();
        const description = toyDescription.trim();

        try {
            showInfoMessage("Сохранение на сервер...");
            const response = await fetch('/api/toys', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key: name, value: description })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Ошибка сохранения');
            }

            showInfoMessage(`Игрушка "${name}" успешно добавлена!`);
            loadToysFromServer();
        } catch (error) {
            showInfoMessage(`Ошибка при добавлении: ${error.message}`);
        }
    }

    async function OnUpdateValueButtonClick() {
        let toyName = prompt("Введите название игрушки для обновления:");
        if (!toyName || toyName.trim() === "") {
            showInfoMessage("Обновление отменено.");
            return;
        }

        const name = toyName.trim();

        try {
            const checkResponse = await fetch(`/api/toys/${encodeURIComponent(name)}`);
            if (!checkResponse.ok) throw new Error('Игрушка не найдена');
            const toy = await checkResponse.json();

            let newDescription = prompt(`Введите новое описание для "${name}":`, toy.description);
            if (!newDescription || newDescription.trim() === "") {
                showInfoMessage("Обновление отменено.");
                return;
            }

            const response = await fetch(`/api/toys/${encodeURIComponent(name)}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ value: newDescription.trim() })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Ошибка обновления');
            }

            showInfoMessage(`Игрушка "${name}" успешно обновлена!`);
            loadToysFromServer();
        } catch (error) {
            showInfoMessage(`${error.message}`);
        }
    }

    async function OnDeleteValueButtonClick() {
        let toyName = prompt("Введите название игрушки для удаления:");
        if (!toyName || toyName.trim() === "") {
            showInfoMessage("Удаление отменено.");
            return;
        }

        const name = toyName.trim();

        const confirmDelete = confirm(`Вы уверены, что хотите удалить игрушку "${name}"?`);
        if (!confirmDelete) {
            showInfoMessage("Удаление отменено.");
            return;
        }

        try {
            const response = await fetch(`/api/toys/${encodeURIComponent(name)}`, {
                method: 'DELETE'
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Ошибка удаления');
            }

            showInfoMessage(`Игрушка "${name}" удалена.`);
            loadToysFromServer();
        } catch (error) {
            showInfoMessage(`Ошибка при удалении: ${error.message}`);
        }
    }

    function downloadToysJSON() {
        window.location.href = '/download-toys';
        showInfoMessage('Начинается скачивание файла...');
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    window.addEventListener('hashchange', onHashChange);

    document.addEventListener('DOMContentLoaded', function() {
        const params = getHashParams();
        currentPage = params.page;
        itemsPerPage = params.limit;
        currentSort = params.sort;
        currentSearchTerm = params.search;

        document.getElementById('searchInput').value = currentSearchTerm;
        document.getElementById('perPageSelect').value = itemsPerPage;

        loadToysFromServer();
    });
</script>